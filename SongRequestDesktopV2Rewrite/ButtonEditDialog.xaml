<Window x:Class="SongRequestDesktopV2Rewrite.ButtonEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit Sound Button"
        Width="800"
        Height="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212"
        Icon="/SRshortLogo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Edit Sound Button"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="White"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Name:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="_nameTextBox"
                     Background="#202020"
                     Foreground="White"
                     BorderBrush="#5B8DEF"
                     BorderThickness="2"
                     Padding="8"
                     FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Icon:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="_iconTextBox"
                     Background="#202020"
                     Foreground="White"
                     BorderBrush="#5B8DEF"
                     BorderThickness="2"
                     Padding="8"
                     FontSize="14"
                     MaxLength="4"/>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Button Color:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <StackPanel x:Name="_colorPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Custom:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Width="60"/>
                <TextBox x:Name="_customColorTextBox"
                         Width="100"
                         Text="#"
                         Background="#202020"
                         Foreground="White"
                         BorderBrush="#5B8DEF"
                         BorderThickness="2"
                         Padding="8,4"
                         FontFamily="Consolas"
                         VerticalContentAlignment="Center"
                         TextChanged="CustomColorTextBox_TextChanged"/>
                <Border x:Name="_customColorPreview"
                        Width="40"
                        Height="28"
                        Margin="8,0,0,0"
                        BorderBrush="#404040"
                        BorderThickness="2"
                        CornerRadius="4"
                        Background="#202020"/>
                <TextBlock Text="Format: #RRGGBB"
                           Foreground="#888888"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="8">
            <TextBlock Text="Sound File:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="_soundFileTextBox"
                         Grid.Column="0"
                         Background="#202020"
                         Foreground="White"
                         BorderBrush="#5B8DEF"
                         BorderThickness="2"
                         Padding="8"
                         FontSize="14"
                         IsReadOnly="True"/>

                <Button x:Name="_browseSoundButton"
                        Grid.Column="1"
                        Content="Browse..."
                        Width="90"
                        Height="32"
                        Margin="8,0,0,0"
                        Background="#5B8DEF"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BrowseSoundButton_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="10">
            <TextBlock Text="Audio Effects:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="_fadeInCheckBox"
                          Content="Fade In"
                          Foreground="White"
                          Margin="0,0,20,0"/>
                <CheckBox x:Name="_fadeOutCheckBox"
                          Content="Fade Out"
                          Foreground="White"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="12">
            <TextBlock Text="Playback Mode:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="_repeatModeCombo"
                      Background="White"
                      Foreground="Black"
                      BorderBrush="#5B8DEF"
                      Padding="8">
                <ComboBoxItem Content="Play-Stop (once)" Tag="none"/>
                <ComboBoxItem Content="Play-Loop (repeat)" Tag="loop"/>
                <ComboBoxItem Content="Play-Overlay (multiple)" Tag="overlay"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="14">
            <TextBlock Text="Volume:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="_volumeSlider"
                        Minimum="0"
                        Maximum="100"
                        Width="700"
                        TickFrequency="10"
                        IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged"/>
                <TextBlock x:Name="_volumeLabel"
                           Text="100%"
                           Foreground="White"
                           FontSize="14"
                           Width="50"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="16">
            <TextBlock Text="MIDI Mapping:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border Background="#1A1A1A"
                    CornerRadius="6"
                    Padding="12"
                    BorderBrush="#5B8DEF"
                    BorderThickness="1">
                <TextBlock x:Name="_midiStatusText"
                           Foreground="#999999"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="18">
            <TextBlock Text="Custom Audio Device:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="_customAudioDevice"
                      Background="White"
                      Foreground="Black"
                      BorderBrush="#5B8DEF"
                      Padding="8">
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="20">
            <TextBlock Text="Keyboard Shortcut:" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="_buttonShortcutEnabledCheckBox"
                          Grid.Column="0"
                          Content="Enabled"
                          Foreground="White"
                          VerticalAlignment="Center"/>

                <Border Grid.Column="2"
                        Background="#202020"
                        BorderBrush="#5B8DEF"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6">
                    <TextBlock x:Name="_buttonShortcutText"
                               Text="(not set)"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </Border>

                <Button x:Name="_setButtonShortcutButton"
                        Grid.Column="4"
                        Content="Set"
                        Background="#5B8DEF"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SetButtonShortcutButton_Click"/>

                <Button x:Name="_clearButtonShortcutButton"
                        Grid.Column="6"
                        Content="Clear"
                        Background="#505050"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ClearButtonShortcutButton_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="22"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Save"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SaveButton_Click"/>
            <Button Content="Cancel"
                    Width="100"
                    Height="36"
                    Background="#505050"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

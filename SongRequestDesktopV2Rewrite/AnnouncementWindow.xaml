<Window x:Class="SongRequestDesktopV2Rewrite.AnnouncementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Announcement"
        Width="900"
        Height="620"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#121212"
        Foreground="White">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#202020"/>
        <SolidColorBrush x:Key="ControlBorder" Color="#303030"/>
        <SolidColorBrush x:Key="ControlAccent" Color="#FF5B8DEF"/>
        <SolidColorBrush x:Key="AccentButtonBackground" Color="#FF5B8DEF"/>
        <SolidColorBrush x:Key="AccentButtonHover" Color="#FF7AD1FF"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentButtonHover}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MicButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="76"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#CC3838"/>
            <Setter Property="BorderBrush" Value="#FF6A6A"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MicBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#55000000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MicBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MicBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider" x:Key="CompactModernSlider">
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}">
                            <Track x:Name="PART_Track"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{Binding Value, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="CompactFilledTrack" Command="Slider.DecreaseLarge" Focusable="False" Height="6">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border CornerRadius="5" Background="{StaticResource ControlAccent}" SnapsToDevicePixels="True"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="CompactRemainingTrack" Command="Slider.IncreaseLarge" Focusable="False" Height="6">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border CornerRadius="5" Background="#3A3A3A" SnapsToDevicePixels="True"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="CompactThumb" Width="14" Height="14" Background="Transparent" RenderTransformOrigin="0.5,0.5" VerticalAlignment="Center">
                                        <Thumb.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Thumb.RenderTransform>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Fill="#F0FFFFFF" Width="14" Height="14"/>
                                                    <Ellipse Fill="{StaticResource ControlAccent}" Width="8" Height="8"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CompactFilledTrack" Property="Height" Value="8"/>
                                <Setter TargetName="CompactRemainingTrack" Property="Height" Value="8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Thumb.DragStarted" SourceName="CompactThumb">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CompactThumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.2"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="CompactThumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.2"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Thumb.DragCompleted" SourceName="CompactThumb">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CompactThumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="CompactThumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="Announcement" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Close" Width="90" DockPanel.Dock="Right" Style="{StaticResource RoundedButton}" Click="CloseButton_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="MicButton"
                        Width="220"
                        Height="220"
                        Content="🎤"
                        Style="{StaticResource MicButtonStyle}"
                        Click="MicButton_Click"
                        PreviewMouseLeftButtonDown="MicButton_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="MicButton_PreviewMouseLeftButtonUp"/>
                <TextBlock x:Name="MicStateText"
                           Text="Ready"
                           Margin="0,14,0,0"
                           Foreground="#D5D5D5"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="Dim music level during announcement (dB)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DockPanel>
                        <TextBlock x:Name="DimDbValueText" Text="30 dB" Margin="12,0,0,0" VerticalAlignment="Center" Width="64"/>
                        <Slider x:Name="DimDbSlider"
                                Minimum="0"
                                Maximum="50"
                                Value="30"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Style="{StaticResource CompactModernSlider}"
                                ValueChanged="DimDbSlider_ValueChanged"/>
                    </DockPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <CheckBox x:Name="PlaySoundCheckBox" Content="Play pre-announcement sound" IsChecked="True" Margin="0,0,0,6" Checked="AnnouncementControl_Changed" Unchecked="AnnouncementControl_Changed" Foreground="White"/>
                    <CheckBox x:Name="PushToTalkCheckBox" Content="Push to talk mode" IsChecked="True" Checked="AnnouncementControl_Changed" Unchecked="AnnouncementControl_Changed" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="SongRequestDesktopV2Rewrite.KeyboardSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Shortcuts"
        Width="680"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Global Keyboard Shortcuts"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"/>

        <Border Grid.Row="2"
                Background="#202020"
                BorderBrush="#303030"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Action" Foreground="#AAAAAA" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Enabled" Foreground="#AAAAAA" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Shortcut" Foreground="#AAAAAA" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Stop All" Foreground="White" VerticalAlignment="Center"/>
                <CheckBox x:Name="StopAllEnabled" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StopAllGestureText" Grid.Row="2" Grid.Column="2" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Row="2" Grid.Column="3" Content="Set" Margin="4,0" Click="SetStopAll_Click"/>
                <Button Grid.Row="2" Grid.Column="4" Content="Clear" Margin="4,0" Click="ClearStopAll_Click"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Volume Up" Foreground="White" VerticalAlignment="Center"/>
                <CheckBox x:Name="VolumeUpEnabled" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="VolumeUpGestureText" Grid.Row="4" Grid.Column="2" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Row="4" Grid.Column="3" Content="Set" Margin="4,0" Click="SetVolumeUp_Click"/>
                <Button Grid.Row="4" Grid.Column="4" Content="Clear" Margin="4,0" Click="ClearVolumeUp_Click"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Volume Down" Foreground="White" VerticalAlignment="Center"/>
                <CheckBox x:Name="VolumeDownEnabled" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="VolumeDownGestureText" Grid.Row="6" Grid.Column="2" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Row="6" Grid.Column="3" Content="Set" Margin="4,0" Click="SetVolumeDown_Click"/>
                <Button Grid.Row="6" Grid.Column="4" Content="Clear" Margin="4,0" Click="ClearVolumeDown_Click"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Next Page" Foreground="White" VerticalAlignment="Center"/>
                <CheckBox x:Name="NextPageEnabled" Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="NextPageGestureText" Grid.Row="8" Grid.Column="2" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Row="8" Grid.Column="3" Content="Set" Margin="4,0" Click="SetNextPage_Click"/>
                <Button Grid.Row="8" Grid.Column="4" Content="Clear" Margin="4,0" Click="ClearNextPage_Click"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Previous Page" Foreground="White" VerticalAlignment="Center"/>
                <CheckBox x:Name="PreviousPageEnabled" Grid.Row="10" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PreviousPageGestureText" Grid.Row="10" Grid.Column="2" Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Row="10" Grid.Column="3" Content="Set" Margin="4,0" Click="SetPreviousPage_Click"/>
                <Button Grid.Row="10" Grid.Column="4" Content="Clear" Margin="4,0" Click="ClearPreviousPage_Click"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Apply"
                    Width="110"
                    Height="34"
                    Margin="0,0,8,0"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Click="ApplyButton_Click"/>
            <Button Content="Cancel"
                    Width="110"
                    Height="34"
                    Background="#505050"
                    Foreground="White"
                    BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

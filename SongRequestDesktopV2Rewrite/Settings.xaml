<Window x:Class="SongRequestDesktopV2Rewrite.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SongRequestDesktopV2Rewrite"
        mc:Ignorable="d"
        Title="Settings - SongRequest"
        Width="1120"
        Height="700"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#121212"
        Foreground="White">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#121212"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#202020"/>
        <SolidColorBrush x:Key="PanelBackgroundLight" Color="#292929"/>
        <SolidColorBrush x:Key="ControlBorder" Color="#303030"/>
        <SolidColorBrush x:Key="AccentButtonBackground" Color="#FF5B8DEF"/>
        <SolidColorBrush x:Key="AccentButtonHover" Color="#FF7AD1FF"/>
        <SolidColorBrush x:Key="DangerButtonBackground" Color="#FFE45757"/>
        <SolidColorBrush x:Key="DangerButtonHover" Color="#FFFF7B7B"/>
        <SolidColorBrush x:Key="SuccessButtonBackground" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="SuccessButtonHover" Color="#FF66D17C"/>
        <SolidColorBrush x:Key="WarningButtonBackground" Color="#FFFFB020"/>
        <SolidColorBrush x:Key="WarningButtonHover" Color="#FFFFC658"/>
        <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#505050"/>
        <SolidColorBrush x:Key="SecondaryButtonHover" Color="#6A6A6A"/>

        <Style TargetType="Button" x:Key="RoundedButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource AccentButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentButtonBackground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource DangerButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBackground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DangerButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource SuccessButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SuccessButtonBackground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource WarningButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WarningButtonBackground}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource WarningButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonBackground}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MappingAssignButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="84"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="MappingClearButton" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Setter Property="Width" Value="84"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="RoundedTextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBorder" Property="BorderBrush" Value="#FF7AD1FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox" x:Key="RoundedPasswordBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="PasswordBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordBorder" Property="BorderBrush" Value="#FF7AD1FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>

        <Style x:Key="RemoteComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2F2F2F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#5038A1FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemoteComboBox" TargetType="ComboBox" BasedOn="{StaticResource RoundedComboBox}">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource RemoteComboBoxItem}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropdownToggle"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          ClickMode="Press">
                                <Border x:Name="ComboBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <Grid>
                                        <ContentPresenter Margin="10,0,30,0"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                        <Path HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Fill="White"
                                              Data="M 0 0 L 8 0 L 4 5 Z"/>
                                    </Grid>
                                </Border>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0"
                                        Background="{StaticResource PanelBackground}"
                                        BorderBrush="{StaticResource ControlBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF5B8DEF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF7AD1FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="CardBorder">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SettingsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PanelBackgroundLight}"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource ControlBorder}"
                                BorderThickness="1"
                                CornerRadius="8,8,0,0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentButtonBackground}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SecondaryButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BFBFBF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorder}" Padding="14,10">
            <StackPanel>
                <TextBlock Text="Settings" FontFamily="Segoe UI Black" FontSize="22"/>
                <TextBlock Text="Changes are only written when you click Save."
                           Style="{StaticResource HintTextStyle}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,10,0,10" Padding="12">
            <TabControl Style="{StaticResource SettingsTabControlStyle}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItemStyle}"/>
                </TabControl.Resources>

                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel Margin="0,10,0,0" ItemWidth="500">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Runtime" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="Controls how often data is refreshed and how many parallel tasks run."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <TextBlock Text="Fetching Timer (seconds)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="FetchingTimerBox" Style="{StaticResource RoundedTextBox}"/>
                                    <TextBlock Text="Lower values refresh more frequently but can increase API usage. API does not have a rate-limit by default, so this is mostly reliant on network quality."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <TextBlock Text="Concurrent Threads" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="ThreadsBox" Style="{StaticResource RoundedTextBox}"/>
                                    <TextBlock Text="Use higher values only if your machine and network can handle it. Higher values improve Performance for high-end systems and reduce performance for low-end systems."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <TextBlock Text="Default Sorting (legacy value)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="DefaultSortingBox" Style="{StaticResource RoundedTextBox}"/>
                                    <TextBlock Text="Kept for compatibility with existing config and server behavior. You do not need to change this under normal circumstances."
                                               Style="{StaticResource HintTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Playback &amp; Presentation" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="Options that affect queueing, screen behavior, and audio handling."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <CheckBox x:Name="PresentationFullscreenCheckBox"
                                              Content="Open presentation in fullscreen mode"
                                              Foreground="White"
                                              Margin="0,0,0,8"/>
                                    <CheckBox x:Name="NormalizeVolumeCheckBox"
                                              Content="Normalize volume between tracks"
                                              Foreground="White"
                                              Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CaptionFallbackCheckBox"
                                              Content="Use YouTube captions as lyrics fallback"
                                              Foreground="White"
                                              Margin="0,0,0,8"/>
                                    <CheckBox x:Name="EnableAnnouncementsCheckBox"
                                              Content="Enable announcements"
                                              Foreground="White"
                                              Margin="0,0,0,8"/>
                                    <TextBlock Text="When lyric APIs fail, use cached YouTube subtitles as fallback lyrics."
                                               Style="{StaticResource HintTextStyle}"
                                               Margin="0,0,0,8"/>

                                    <Border Margin="0,2,0,0" CornerRadius="8" Padding="2">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF5B8DEF" Offset="0.0"/>
                                                <GradientStop Color="#FFDA70D6" Offset="0.5"/>
                                                <GradientStop Color="#FFFF8C00" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>2</Border.BorderThickness>
                                        <Border Background="#1E1E2E" CornerRadius="6" Padding="10,8">
                                            <StackPanel>
                                                <CheckBox x:Name="AutoEnqueueCheckBox"
                                                          Content="✈ Autopilot Mode"
                                                          Foreground="White"/>
                                                <TextBlock Text="Automatically adds newly sent-in songs to the player queue."
                                                           Style="{StaticResource HintTextStyle}"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Security &amp; Server">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel Margin="0,10,0,0" ItemWidth="500">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Server Connection" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="Base URL and request URL used by fetch and presentation features."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <TextBlock Text="Server Address" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="AddressBox" Style="{StaticResource RoundedTextBox}"/>
                                    <TextBlock Text="Example: http://127.0.0.1:5000"
                                               Style="{StaticResource HintTextStyle}"/>

                                    <TextBlock Text="Presentation Request URL (QR Code)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="RequestUrlBox" Style="{StaticResource RoundedTextBox}" Text="https://example.com/request"/>
                                    <TextBlock Text="Shown to users for submitting requests from their devices."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <Separator Margin="0,4,0,10" Background="{StaticResource ControlBorder}"/>

                                    <TextBlock Text="Server-side Send-In Status" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="Current server permission for receiving new song requests."
                                               Style="{StaticResource HintTextStyle}"
                                               Margin="0,2,0,6"/>
                                    <WrapPanel>
                                        <CheckBox x:Name="SendinAllowedCheckBox"
                                                  Content="Sending Allowed"
                                                  Foreground="White"
                                                  IsEnabled="False"
                                                  Margin="0,4,10,0"/>
                                        <Button x:Name="ToggleSendinButton"
                                                Content="Toggle"
                                                Width="90"
                                                Height="30"
                                                Style="{StaticResource WarningButton}"
                                                Click="ToggleSendinButton_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Authentication" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="Administrator authentication is required for SongRequest to work correctly."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <TextBlock Text="Bearer Token / JWT" Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <PasswordBox x:Name="TokenPasswordBox"
                                                     Grid.Column="0"
                                                     Style="{StaticResource RoundedPasswordBox}"
                                                     PasswordChanged="TokenPasswordBox_PasswordChanged"/>
                                        <TextBox x:Name="TokenRevealBox"
                                                 Grid.Column="0"
                                                 Style="{StaticResource RoundedTextBox}"
                                                 Visibility="Collapsed"
                                                 TextChanged="TokenRevealBox_TextChanged"/>
                                        <Button x:Name="ToggleTokenVisibilityButton"
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Width="40"
                                                Height="32"
                                                ToolTip="Show or hide token"
                                                Content="👁"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="ToggleTokenVisibilityButton_Click"/>
                                    </Grid>

                                    <TextBlock Text="Tip: Keep this hidden while streaming or screen sharing."
                                               Style="{StaticResource HintTextStyle}"
                                               Margin="0,8,0,8"/>

                                    <Button x:Name="RegisterAuth"
                                            Content="Authenticate using SchülerApp Account"
                                            Width="240"
                                            Style="{StaticResource AccentButton}"
                                            Click="RegisterAuth_OnClick"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Console &amp; Tools">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border Style="{StaticResource CardBorder}" Margin="0,10,10,10">
                            <StackPanel>
                                <TextBlock Text="Console Controls" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Manage the main window console for debugging and moderation workflows."
                                           Style="{StaticResource HintTextStyle}"/>

                                <TextBlock Text="Message to append" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="AppendTextBox"
                                         Style="{StaticResource RoundedTextBox}"
                                         Text="Test message from Settings"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         MinHeight="80"/>

                                <WrapPanel Margin="0,10,0,0">
                                    <Button x:Name="AppendConsoleButton" Content="Append to Console" Width="150" Style="{StaticResource AccentButton}" Click="AppendConsoleButton_Click"/>
                                    <Button x:Name="ClearConsoleButton" Content="Clear Console" Width="130" Margin="8,0,0,0" Style="{StaticResource DangerButton}" Click="ClearConsoleButton_Click"/>
                                </WrapPanel>

                                <TextBlock Text="Console text color" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="ConsoleColorCombo" Width="180" SelectedIndex="1" Style="{StaticResource RoundedComboBox}">
                                        <ComboBoxItem>Green</ComboBoxItem>
                                        <ComboBoxItem>Red</ComboBoxItem>
                                        <ComboBoxItem>White</ComboBoxItem>
                                    </ComboBox>
                                    <Button x:Name="ApplyColorButton" Content="Apply Color" Width="120" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Click="ApplyColorButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Remote Control">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,10,0,0">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Music Player Mappings" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="These mappings work globally across app windows. Use multi-key combinations for keyboard shortcuts."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Action" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="Key Bind" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="4" Text="MIDI Mapping" FontWeight="Bold"/>

                                        <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="Play / Pause"/>
                                        <TextBlock x:Name="KeybindPlayPauseText" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="1" Grid.Column="2" Margin="6,8,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="PlayPause" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="3" Margin="6,8,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="PlayPause" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiPlayPauseText" Grid.Row="1" Grid.Column="4" Margin="0,10,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="1" Grid.Column="5" Margin="6,8,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="PlayPause" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="6" Margin="6,8,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="PlayPause" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="Skip Next"/>
                                        <TextBlock x:Name="KeybindSkipNextText" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="2" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="SkipNext" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="SkipNext" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiSkipNextText" Grid.Row="2" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="2" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="SkipNext" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="SkipNext" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="3" Margin="0,8,0,0" Text="Previous"/>
                                        <TextBlock x:Name="KeybindPreviousText" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="3" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Previous" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Previous" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiPreviousText" Grid.Row="3" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="3" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Previous" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Previous" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="4" Margin="0,8,0,0" Text="Stop"/>
                                        <TextBlock x:Name="KeybindStopText" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="4" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Stop" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Stop" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiStopText" Grid.Row="4" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="4" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Stop" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Stop" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="5" Margin="0,8,0,0" Text="Volume Up"/>
                                        <TextBlock x:Name="KeybindVolumeUpText" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="5" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="VolumeUp" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="5" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="VolumeUp" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiVolumeText" Grid.Row="5" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="5" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Volume" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="5" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Volume" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="6" Margin="0,8,0,0" Text="Volume Down"/>
                                        <TextBlock x:Name="KeybindVolumeDownText" Grid.Row="6" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="6" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="VolumeDown" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="6" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="VolumeDown" Click="ClearKeybindButton_Click"/>
                                        <TextBlock Grid.Row="6" Grid.Column="4" Margin="0,8,0,0" Text="(shares Volume MIDI row above)" Foreground="#AAAAAA"/>

                                        <TextBlock Grid.Row="7" Margin="0,8,0,0" Text="Crossfade Up"/>
                                        <TextBlock x:Name="KeybindCrossfadeUpText" Grid.Row="7" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="7" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="CrossfadeUp" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="CrossfadeUp" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiCrossfadeText" Grid.Row="7" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="7" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Crossfade" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="7" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Crossfade" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="8" Margin="0,8,0,0" Text="Crossfade Down"/>
                                        <TextBlock x:Name="KeybindCrossfadeDownText" Grid.Row="8" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="8" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="CrossfadeDown" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="8" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="CrossfadeDown" Click="ClearKeybindButton_Click"/>
                                        <TextBlock Grid.Row="8" Grid.Column="4" Margin="0,8,0,0" Text="(shares Crossfade MIDI row above)" Foreground="#AAAAAA"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Announcement Mappings" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="Remote actions for announcement control and announcement settings."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="240"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Action" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="Key Bind" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="4" Text="MIDI Mapping" FontWeight="Bold"/>

                                        <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="Announcement (Start/Toggle)"/>
                                        <TextBlock x:Name="KeybindAnnouncementText" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="1" Grid.Column="2" Margin="6,8,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Announcement" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="3" Margin="6,8,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Announcement" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiAnnouncementText" Grid.Row="1" Grid.Column="4" Margin="0,10,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="1" Grid.Column="5" Margin="6,8,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="Announcement" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="6" Margin="6,8,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="Announcement" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="Toggle pre-announcement sound"/>
                                        <TextBlock x:Name="KeybindAnnouncementPlaySoundToggleText" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="2" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementPlaySoundToggle" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementPlaySoundToggle" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiAnnouncementPlaySoundToggleText" Grid.Row="2" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="2" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementPlaySoundToggle" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="2" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementPlaySoundToggle" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="3" Margin="0,8,0,0" Text="Toggle push-to-talk mode"/>
                                        <TextBlock x:Name="KeybindAnnouncementPushToTalkToggleText" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="3" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementPushToTalkToggle" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementPushToTalkToggle" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiAnnouncementPushToTalkToggleText" Grid.Row="3" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="3" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementPushToTalkToggle" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="3" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementPushToTalkToggle" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="4" Margin="0,8,0,0" Text="Dim level (dB) up/down"/>
                                        <TextBlock x:Name="KeybindAnnouncementDimDbUpText" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="4" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementDimDbUp" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementDimDbUp" Click="ClearKeybindButton_Click"/>
                                        <TextBlock x:Name="MidiAnnouncementDimDbText" Grid.Row="4" Grid.Column="4" Margin="0,8,0,0" Text="Not assigned" TextWrapping="Wrap"/>
                                        <Button Grid.Row="4" Grid.Column="5" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementDimDb" Click="AssignMidiButton_Click"/>
                                        <Button Grid.Row="4" Grid.Column="6" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementDimDb" Click="ClearMidiButton_Click"/>

                                        <TextBlock Grid.Row="5" Margin="0,8,0,0" Text="Dim level (dB) down"/>
                                        <TextBlock x:Name="KeybindAnnouncementDimDbDownText" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Text="Not assigned"/>
                                        <Button Grid.Row="5" Grid.Column="2" Margin="6,6,0,0" Content="Assign" Style="{StaticResource MappingAssignButton}" Tag="AnnouncementDimDbDown" Click="AssignKeybindButton_Click"/>
                                        <Button Grid.Row="5" Grid.Column="3" Margin="6,6,0,0" Content="Clear" Style="{StaticResource MappingClearButton}" Tag="AnnouncementDimDbDown" Click="ClearKeybindButton_Click"/>
                                        <TextBlock Grid.Row="5" Grid.Column="4" Margin="0,8,0,0" Text="(shares Dim MIDI row above)" Foreground="#AAAAAA"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="MIDI Devices &amp; Live Feedback" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="Select MIDI input/output devices for remote control. Feedback LEDs update live for play state and slider positions."
                                               Style="{StaticResource HintTextStyle}"/>

                                    <CheckBox x:Name="RemoteMidiEnabledCheckBox"
                                              Content="Enable MIDI remote control"
                                              Foreground="White"
                                              Margin="0,4,0,10"
                                              Checked="RemoteMidiDevice_SelectionChanged"
                                              Unchecked="RemoteMidiDevice_SelectionChanged"/>

                                    <TextBlock Text="MIDI Input Device" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="RemoteMidiInputCombo"
                                              Style="{StaticResource RemoteComboBox}"
                                              SelectionChanged="RemoteMidiCombo_SelectionChanged"/>

                                    <TextBlock Text="MIDI Output Device" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="RemoteMidiOutputCombo"
                                              Style="{StaticResource RemoteComboBox}"
                                              SelectionChanged="RemoteMidiCombo_SelectionChanged"/>

                                    <TextBlock x:Name="RemoteMidiStatusText"
                                               Text="MIDI status unknown"
                                               Foreground="#D0D0D0"
                                               Margin="0,8,0,2"/>
                                    <TextBlock x:Name="RemoteMidiLastMessageText"
                                               Text="No MIDI activity yet."
                                               Foreground="#9A9A9A"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12,10">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Left"
                           Text=""
                           Foreground="LightGray"
                           VerticalAlignment="Center"
                           Margin="4,0,20,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveButton" Content="Save" Width="110" Margin="6,0" Style="{StaticResource SuccessButton}" Click="SaveButton_Click"/>
                    <Button x:Name="ReloadButton" Content="Reload" Width="110" Margin="6,0" Style="{StaticResource SecondaryButton}" Click="ReloadButton_Click"/>
                    <Button x:Name="CloseButton" Content="Close" Width="110" Margin="6,0" Style="{StaticResource DangerButton}" Click="CloseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
